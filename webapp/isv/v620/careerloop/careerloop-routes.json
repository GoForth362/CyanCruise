        {
          "name": "ensure plan",
          "method": "POST",
          "path": "/cc001/career-plan/ensure",
          "body": ["userId"],
          "userIdRequired": true,
          "dto": "CareerPlanSummaryDto",
          "fallback": "Show create-plan action."
        }
      ]
    },
    {
      "key": "employment-insight",
      "title": "就业洞察",
      "ipdPaths": ["pages/cdut-employment/index", "pages/cdut-employment/detail"],
      "target": "index.html#employment-insight",
      "status": "available",
      "webApis": [
        {
          "name": "employment insight",
          "method": "POST",
          "path": "/cc001/career-employment/insight/get",
