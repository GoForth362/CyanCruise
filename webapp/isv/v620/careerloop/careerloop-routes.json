{
  "platform": "kingdee-cosmic-webapp",
  "change": "migrate-webapp-careerloop-entry",
  "sourceProject": "F:\\Project\\IPD",
  "targetRoot": "webapp/isv/v620/careerloop",
  "identity": {
    "production": "pending-cosmic-login-context",
    "development": ["query:userId", "localStorage:careerloop.userId", "manual-input"],
    "rule": "Do not call user-owned WebAPI without an explicit userId."
  },
  "routes": [
    {
      "key": "workbench",
      "title": "CareerLoop 工作台",
      "ipdPaths": ["pages/home/index"],
      "target": "index.html#workbench",
      "status": "available",
      "webApis": [
        {
          "name": "career profile snapshot",
          "method": "POST",
          "path": "/cc001/career-profile/snapshot/get",
          "body": ["userId"],
          "userIdRequired": true,
          "dto": "UserProfileSnapshot",
          "fallback": "Show onboarding-required or empty profile state."
        },
        {
          "name": "today action by user",
          "method": "POST",
          "path": "/cc001/career-agent/today/get",
          "body": ["userId"],
          "userIdRequired": true,
          "dto": "CareerAgentTodayDto",
          "fallback": "Show recoverable today-action unavailable state."
        }
      ]
    },
    {
      "key": "onboarding",
      "title": "新用户引导",
      "ipdPaths": ["pages/onboarding/index"],
      "target": "index.html#onboarding",
      "status": "available",
      "webApis": [
        {
          "name": "save onboarding",
          "method": "POST",
          "path": "/cc001/career-profile/onboarding/save",
          "body": ["userId", "request"],
          "userIdRequired": true,
          "dto": "CareerProfileOnboardingRequest -> UserProfileSnapshot",
          "fallback": "Keep the local form values and show save failed state."
        }
      ]
    },
    {
      "key": "today-action",
      "title": "今日行动",
      "ipdPaths": ["pages/agent/index"],
      "compatibleTargets": [
        "/pages/agent/index",
        "pages/agent/index",
        "/pages/assistant/index",
        "pages/assistant/index",
        "/pages/resume/index",
        "pages/resume/index",
        "/pages/resume-ai/index",
        "pages/resume-ai/index",
        "/pages/assessment/index",
        "pages/assessment/index",
        "/pages/interview/index",
        "pages/interview/index"
      ],
      "target": "index.html#today-action",
      "status": "available",
      "webApis": [
        {
          "name": "today action by user",
          "method": "POST",
          "path": "/cc001/career-agent/today/get",
          "body": ["userId"],
          "userIdRequired": true,
          "dto": "CareerAgentTodayDto",
          "fallback": "Show rule result unavailable and keep quick actions visible."
        }
      ]
    },
    {
      "key": "assessment",
      "title": "职业测评",
      "ipdPaths": ["pages/assessment/index", "pages/assessment/quiz", "pages/assessment/result"],
