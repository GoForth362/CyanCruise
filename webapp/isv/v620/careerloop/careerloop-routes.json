      "status": "available",
      "webApis": [
        {
          "name": "career resource feed",
          "method": "POST",
          "path": "/cc001/career-employment/resources/list",
          "body": ["userId"],
          "userIdRequired": false,
          "dto": "CareerResourceFeedDto",
          "fallback": "Show an empty resources state and keep the workbench navigable."
