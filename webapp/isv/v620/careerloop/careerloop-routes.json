    {
      "key": "subscriptions",
      "title": "订阅授权",
      "ipdPaths": ["utils/wxSubscribe.ts", "WechatSubscribeController", "WechatSubscribeService"],
      "target": "index.html#subscriptions",
      "status": "entry-only",
      "webApis": [
        {
          "name": "record subscription grant",
          "method": "POST",
          "path": "/cc001/notifications/subscription/grant",
          "body": ["request"],
          "userIdRequired": true,
          "dto": "SubscriptionGrantRequest -> List<SubscriptionQuotaDto>",
          "fallback": "Ignore grant result best-effort; never block the primary user action."
        },
        {
          "name": "list subscription quota",
          "method": "POST",
          "path": "/cc001/notifications/subscription/quota",
          "body": ["userId"],
          "userIdRequired": true,
          "dto": "List<SubscriptionQuotaDto>",
          "fallback": "Treat quota as unknown and do not request external send."
        },
        {
          "name": "attempt subscription send",
          "method": "POST",
          "path": "/cc001/notifications/subscription/send",
          "body": ["request"],
          "userIdRequired": true,
          "dto": "SubscriptionSendResult",
          "fallback": "Return skipped/unavailable and keep in-app notification as canonical."
        }
      ]
    },
    {
      "key": "weekly-report",
