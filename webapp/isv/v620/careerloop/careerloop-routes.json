  "platform": "kingdee-cosmic-webapp",
  "change": "migrate-cosmic-platform-mounting",
  "sourceProject": "F:\\Project\\IPD",
  "targetRoot": "webapp/isv/v620/careerloop",
  "pageShell": {
    "change": "migrate-webapp-careerloop-pages",
    "implementation": "static-hash-route-states",
    "visibleUserRoutes": [
      "workbench",
      "onboarding",
      "today-action",
      "assessment",
      "resume",
      "file-upload-preview",
      "resume-diagnosis",
      "career-plan",
      "interview",
      "assistant",
      "messages",
      "employment-insight",
      "career-resources"
    ],
    "adminRoutes": ["admin-console"],
    "entryOnlyRoutes": ["assessment", "file-upload-preview", "subscriptions", "weekly-report", "admin-console"],
    "stateModel": ["loading", "empty", "success", "identity-required", "forbidden", "unavailable", "backend-error", "pending"],
    "runtimeRule": "Page states are rebuilt as CyanCruise static webapp assets and do not require IPD Vue, uni-app, Pinia, Vite, uView, axios interceptors, Spring Boot, JPA, Flyway, or Java 17 runtime code."
  },
  "identity": {
    "production": {
      "mode": "cosmic-platform-context",
      "user": "Cosmic login context user mapped to CareerLoop userId by platform adapter",
      "admin": "Cosmic login context user with ADMIN or platform administrator authority mapped to adminId",
      "status": "adapter-required",
      "backendAdapter": "CareerLoopIdentityResolver -> IdentityAwareCareerLoopWebApiBoundary",
      "adapterEnablement": {
        "property": "cc001.identity.adapter.enabled",
        "enabledValue": "true",
        "diagnosticsProperty": "cc001.identity.adapter.diagnostics.enabled",
        "defaultBehavior": "disabled-safe-identity-required",
        "provider": "CosmicIdentityContextProvider"
      },
      "candidateFields": {
        "userId": ["userId", "personId", "operatorId", "uid"],
        "adminId": ["adminId", "userId", "operatorId"],
        "orgId": ["orgId", "organizationId", "deptId"],
        "roles": ["roles", "roleCodes", "role", "permissionCodes"],
        "ip": ["ip"],
        "userAgent": ["userAgent", "ua"]
      },
      "adminAliases": ["ADMIN", "COSMIC_ADMIN", "PLATFORM_ADMIN"],
      "disabledBehavior": "Production WebAPI remains identity-required and never falls back to development identity."
    },
    "development": {
      "mode": "explicit-fallback",
      "sources": ["query:userId", "localStorage:careerloop.userId", "manual-input"],
      "rule": "Development fallback must be explicit and must not be treated as production identity."
    },
    "rule": "Do not call user-owned or admin-owned WebAPI without an explicit platform or development identity.",
    "backendStatuses": ["OK", "IDENTITY_REQUIRED", "FORBIDDEN", "IDENTITY_MISMATCH"],
    "mismatchRule": "When request userId/adminId conflicts with resolved platform identity, the backend boundary rejects the call before invoking protected services."
  },
  "sourceEvidence": {
    "pageAndMenuSemantics": [
      "F:\\Project\\IPD\\frontend\\src\\pages.json",
