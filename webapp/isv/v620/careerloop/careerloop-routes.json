          "name": "mark notification read",
          "method": "POST",
          "path": "/cc001/notifications/read",
          "body": ["userId", "notificationId"],
          "userIdRequired": true,
          "dto": "NotificationOperationResult",
          "fallback": "Keep local unread state and show operation failed state."
        },
        {
          "name": "mark all notifications read",
          "method": "POST",
          "path": "/cc001/notifications/read-all",
          "body": ["userId"],
          "userIdRequired": true,
          "dto": "NotificationOperationResult",
          "fallback": "Keep message list navigable."
        },
        {
          "name": "delete notification",
          "method": "POST",
          "path": "/cc001/notifications/delete",
          "body": ["userId", "notificationId"],
          "userIdRequired": true,
          "dto": "NotificationOperationResult",
          "fallback": "Restore deleted item in the UI."
        }
