      "target": "index.html#resume",
      "status": "available",
      "webApis": [
        {
          "name": "list resumes",
          "method": "POST",
          "path": "/cc001/resume/list",
          "body": ["userId"],
          "userIdRequired": true,
          "dto": "List<ResumeRecordDto>",
          "fallback": "Show no resume state."
        },
        {
          "name": "create resume metadata",
          "method": "POST",
          "path": "/cc001/resume/create",
          "body": ["userId", "request"],
          "userIdRequired": true,
