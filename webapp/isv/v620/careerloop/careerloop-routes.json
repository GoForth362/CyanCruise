      "webApis": [
        {
          "name": "submit assessment",
          "method": "POST",
          "path": "/cc001/assessment/submit",
          "body": ["userId", "scale", "request"],
          "userIdRequired": true,
          "dto": "AssessmentSubmitRequest -> AssessmentScoreResult",
          "fallback": "Show assessment entry and profile result summary only."
