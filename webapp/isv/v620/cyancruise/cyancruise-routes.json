    "stateModel": ["loading", "empty", "success", "identity-required", "forbidden", "unavailable", "backend-error", "pending"],
    "runtimeRule": "Page states are rebuilt as CyanCruise static webapp assets and do not require IPD Vue, uni-app, Pinia, Vite, uView, axios interceptors, Spring Boot, JPA, Flyway, or Java 17 runtime code."
  },
  "identity": {
    "production": {
      "mode": "cosmic-platform-context",
      "user": "Cosmic login context user mapped to CareerLoop userId by platform adapter",
      "admin": "Cosmic login context user with ADMIN or platform administrator authority mapped to adminId",
      "status": "adapter-required",
      "backendAdapter": "CareerLoopIdentityResolver -> IdentityAwareCareerLoopWebApiBoundary",
      "adapterEnablement": {
        "property": "cc001.identity.adapter.enabled",
        "enabledValue": "true",
        "diagnosticsProperty": "cc001.identity.adapter.diagnostics.enabled",
        "defaultBehavior": "disabled-safe-identity-required",
        "provider": "CosmicIdentityContextProvider"
      },
      "candidateFields": {
        "userId": ["userId", "personId", "operatorId", "uid"],
        "adminId": ["adminId", "userId", "operatorId"],
        "orgId": ["orgId", "organizationId", "deptId"],
        "roles": ["roles", "roleCodes", "role", "permissionCodes"],
        "ip": ["ip"],
        "userAgent": ["userAgent", "ua"]
      },
      "adminAliases": ["ADMIN", "COSMIC_ADMIN", "PLATFORM_ADMIN"],
      "disabledBehavior": "Production WebAPI remains identity-required and never falls back to development identity."
    },
    "development": {
      "mode": "explicit-fallback",
      "sources": ["query:userId", "localStorage:cyancruise.userId", "manual-input"],
      "rule": "Development fallback must be explicit and must not be treated as production identity."
    },
    "rule": "Do not call user-owned or admin-owned WebAPI without an explicit platform or development identity.",
    "backendStatuses": ["OK", "IDENTITY_REQUIRED", "FORBIDDEN", "IDENTITY_MISMATCH"],
    "mismatchRule": "When request userId/adminId conflicts with resolved platform identity, the backend boundary rejects the call before invoking protected services."
  },
  "aiProvider": {
    "change": "migrate-ai-provider-production-adapter",
    "mode": "openai-compatible-production-adapter",
    "backendAdapter": "AiProviderAdapterFactory -> CompatibleEndpointAiProviderAdapter -> DefaultAiGateway",
    "adapterEnablement": {
      "property": "cc001.ai.provider.enabled",
      "enabledValue": "true",
      "endpointProperty": "cc001.ai.provider.endpoint",
      "apiKeyProperty": "cc001.ai.provider.apiKey",
      "modelProperty": "cc001.ai.provider.model",
      "timeoutProperty": "cc001.ai.provider.timeoutSeconds",
      "retryProperty": "cc001.ai.provider.retryOn5xx",
      "diagnosticsProperty": "cc001.ai.provider.diagnostics.enabled",
      "defaultBehavior": "disabled-safe-ai-unavailable"
    },
    "requestMapping": ["model", "messages", "tools", "tool_choice", "stream"],
    "responseMapping": ["content", "finishReason", "toolCalls", "usage", "modelName", "errorCode", "diagnostics"],
    "secretRule": "Route metadata records property names and fallback behavior only; endpoint secrets, apiKey values, and Authorization headers must never be stored here.",
    "fallback": "When provider is disabled, incomplete, timed out, or invalid, backend returns AI unavailable or scenario fallback without fake successful AI content."
  },
  "productionReadiness": {
    "change": "migrate-production-readiness-checklist",
    "status": "checklist-defined",
    "document": "docs/careerloop-production-readiness-checklist.md",
    "sourceSemantics": [
      "production configuration must use property names and tenant-owned values, never checked-in secrets",
      "health checks must be observable through Cosmic-compatible probes or representative WebAPI checks",
      "backup, restore, monitoring, and rollback are release evidence, not migrated IPD bash or Docker runtime"
    ],
    "automatedChecks": [
      {
        "key": "openspec-current",
        "command": "openspec validate migrate-production-readiness-checklist --strict",
        "releaseGate": "blocking"
      },
      {
        "key": "openspec-all",
        "command": "openspec validate --all --strict",
        "releaseGate": "blocking"
      },
      {
        "key": "jdk8-build",
        "command": "$env:JAVA_HOME='F:\\kingdee\\ENV\\jdk'; $env:Path=\"$env:JAVA_HOME\\bin;$env:Path\"; .\\gradlew.bat clean build",
        "releaseGate": "blocking"
      },
      {
        "key": "route-map",
        "command": "node webapp\\isv\\v620\\cyancruise\\validate-routes.js",
        "releaseGate": "blocking"
      },
      {
        "key": "webapp-js",
        "command": "node --check webapp\\isv\\v620\\cyancruise\\assets\\app.js",
        "releaseGate": "blocking"
      }
    ],
    "tenantManualChecks": [
      {
        "key": "cosmic-login-context",
        "status": "manual-required",
        "properties": [
          "cc001.identity.adapter.enabled",
          "cc001.identity.login.provider.enabled",
          "cc001.identity.login.provider.bridgeClass"
        ],
        "fallback": "identity-required or forbidden; never development identity"
      },
      {
        "key": "cosmic-file-service",
        "status": "manual-required",
        "properties": ["cc001.file.adapter.enabled"],
        "fallback": "unavailable or skipped; never production use of local/in-memory file storage"
      },
      {
        "key": "ai-provider",
        "status": "manual-required",
        "properties": [
          "cc001.ai.provider.enabled",
          "cc001.ai.provider.endpoint",
          "cc001.ai.provider.apiKey",
          "cc001.ai.provider.model",
          "cc001.ai.provider.timeoutSeconds",
          "cc001.ai.provider.retryOn5xx",
          "cc001.ai.provider.diagnostics.enabled"
        ],
        "fallback": "AI unavailable or scenario rule fallback"
      },
      {
        "key": "kddt-menu-mounts",
        "status": "manual-required",
        "fallback": "unpublish menu or route"
      },
      {
        "key": "datamodel-storage",
        "status": "manual-required",
        "fallback": "block production until tenant storage and backup scope are confirmed"
      },
      {
        "key": "health-monitoring-backup-restore",
        "status": "manual-required",
        "fallback": "block release until probe, monitoring, backup, restore, and rollback evidence are approved"
      }
    ],
    "deferredCapabilities": [
      "real WeChat subscription/template sending",
      "external employment crawling and full-detail pages",
      "voice ASR/TTS and digital-human interview",
      "complete Vue/Element admin console",
      "customer-specific datamodel, RBAC, and master-data adapters",
      "customer monitoring channel automation"
    ],
    "secretRule": "Only property names, validation intent, fallback behavior, and non-sensitive command strings may be recorded; apiKey values, Authorization headers, endpoint secrets, customer-private values, server addresses, and production credentials are forbidden.",
    "rollback": [
      "disable cc001.ai.provider.enabled to return AI unavailable or scenario fallback",
      "disable cc001.file.adapter.enabled to return file unavailable or skipped",
      "disable identity adapter/provider to return identity-required or forbidden",
      "unpublish KDDT menu or route mount",
      "roll back to the previous Cosmic package using customer-approved release procedure"
    ]
  },
