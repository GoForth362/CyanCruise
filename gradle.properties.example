#systemProp.cc001.kapi.token.endpoint=http://10.0.0.8:8080/ierp/kapi/oauth2/getToken
#systemProp.cc001.kapi.token.clientId=cc001
#systemProp.cc001.kapi.token.clientSecret=<AccessToken authentication secret>
#--Optional fallback only. By default username/accountId are resolved from the current Cosmic RequestContext.
