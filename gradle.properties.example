#systemProp.cc001.kapi.token.timeoutSeconds=10
#systemProp.cc001.kapi.token.cacheSeconds=3300
#systemProp.cc001.kapi.token.expirySkewSeconds=60
# Optional. If omitted, CyanCruise derives this from the token endpoint base URL.
