#systemProp.cc001.profile.postgresql.password=<password>
#systemProp.cc001.profile.postgresql.schema=public
#systemProp.cc001.profile.postgresql.initialize=false

#--CyanCruise shared business-state storage. Use this for runtime storage adapters replacing local filestorage.
#systemProp.cc001.storage.backend=postgresql
