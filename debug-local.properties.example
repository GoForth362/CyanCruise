cosmic.server.host=127.0.0.1
cosmic.zk.port=2181
cosmic.zk.user=zookeeper
cosmic.zk.password=
cosmic.mc.port=8090
cosmic.web.port=8881
cosmic.web.bind.ip=0.0.0.0
cosmic.web.public.url=http://10.0.0.8:8881/ierp
cosmic.shared.runtime.enabled=true
cc001.profile.storage.adapter=postgresql
cc001.profile.postgresql.url=jdbc:postgresql://10.0.0.8:5432/cyancruise
cc001.profile.postgresql.username=cyancruise_app
cc001.profile.postgresql.password=
cc001.profile.postgresql.schema=public
cc001.profile.postgresql.initialize=false
cosmic.cluster.number=cosmic
cosmic.tenant.number=ierp
cosmic.monitor.es.url=http://10.0.0.8:9200/

# Employment planning Agent SDK integration.
cc001.agent.platform.employment.enabled=false
cc001.agent.platform.employment.agentNumber=
# cc001.agent.platform.employment.taskFlowCode=

# Study planning uses one independent service for each selected direction.
# A configured taskFlowCode runs directly; otherwise agentNumber is called.
cc001.agent.platform.study.postgraduate.enabled=false
cc001.agent.platform.study.postgraduate.agentNumber=
# cc001.agent.platform.study.postgraduate.taskFlowCode=
cc001.agent.platform.study.recommendation.enabled=false
cc001.agent.platform.study.recommendation.agentNumber=
# cc001.agent.platform.study.recommendation.taskFlowCode=
cc001.agent.platform.study.abroad.enabled=false
cc001.agent.platform.study.abroad.agentNumber=
# cc001.agent.platform.study.abroad.taskFlowCode=

# The thirteen postgraduate, recommendation and overseas-study page tools share
# one published companion Agent. Its task flow remains inside the Agent.
cc001.agent.platform.study.companion.enabled=false
cc001.agent.platform.study.companion.agentNumber=
# Optional reliability fallback. The Agent is called first; if it returns a mismatched
# or malformed task result, the same published task flow receives the original JSON.
cc001.agent.platform.study.companion.taskFlowCode=

# Profile enrichment Agent SDK integration. This agent handles both one
# assessment interpretation and the combined deep profile request modes.
cc001.agent.platform.profile.enabled=false
cc001.agent.platform.profile.agentNumber=
# cc001.agent.platform.profile.taskFlowCode=

# Resume diagnosis Agent SDK integration.
cc001.agent.platform.resume.enabled=false
cc001.agent.platform.resume.agentNumber=
# cc001.agent.platform.resume.taskFlowCode=

#本地向量数据
#vector.es.url=http://127.0.0.1:9200/

# Optional full overrides. Use these only when host/port fields are not enough.
# cosmic.config.url=127.0.0.1:2181?user=zookeeper&password=your-password
# cosmic.mc.url=http://127.0.0.1:8090/
